{
  "name": "PanelAdminGrit",
  "private": true,
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:serve": "npx serve web-build -p 8081",
    "postinstall": "node scripts/fix-all-packages.js && node scripts/patch-react-native.js",
    "electron:run": "npm run build:web:quick && concurrently \"npm run web:serve\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:dev": "npm run build:web:quick && concurrently \"npm run web:serve\" \"wait-on http://localhost:8081 && electron electron/main.js --dev\"",
    "build:web": "npx expo export --platform web --output-dir web-build && node fix-html-for-electron.js",
    "build:web:quick": "npx expo export --platform web --output-dir web-build && node fix-html-for-electron.js",
    "build:electron": "npm run build:web && electron-builder --config electron-builder.json",
    "build:electron:win": "npm run build:web && electron-builder --win --config electron-builder.json",
    "build:electron:mac": "npm run build:web && electron-builder --mac --config electron-builder.json",
    "build:electron:linux": "npm run build:web && electron-builder --linux --config electron-builder.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "check-logs": "node scripts/remove-console-logs.js",
    "validate": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "@expo-google-fonts/baloo-2": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@sindresorhus/is": "^7.2.0",
    "@szmarczak/http-timer": "^5.0.1",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.2",
    "axios": "^1.6.0",
    "defer-to-connect": "^2.0.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "^14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "got": "^14.6.6",
    "memoize-one": "5.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-google-places-autocomplete": "^2.5.7",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-styled": "^0.4.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^5.0.2",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.2",
    "yup": "^1.7.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@eslint/js": "^9.37.0",
    "@expo/ngrok": "^4.1.3",
    "@react-native/eslint-config": "^0.83.1",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "null-loader": "^4.0.1",
    "prettier": "^3.8.1",
    "react-native-dotenv": "^3.4.11",
    "typescript": "~5.9.2",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "memoize-one": "5.2.1"
  }
}
