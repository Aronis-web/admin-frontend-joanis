<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 ERP-aio"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ayer"
            android:textSize="11sp"
            android:textColor="#64748B" />
    </LinearLayout>

    <!-- Filtros de período -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_today"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Hoy"
            android:textSize="10sp"
            android:textColor="#64748B"
            android:background="@drawable/filter_button"
            android:layout_marginEnd="4dp"
            style="?android:attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn_yesterday"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Ayer"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/filter_button_active"
            android:layout_marginEnd="4dp"
            style="?android:attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn_week"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Semana"
            android:textSize="10sp"
            android:textColor="#64748B"
            android:background="@drawable/filter_button"
            android:layout_marginEnd="4dp"
            style="?android:attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn_month"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Mes"
            android:textSize="10sp"
            android:textColor="#64748B"
            android:background="@drawable/filter_button"
            style="?android:attr/borderlessButtonStyle" />
    </LinearLayout>

    <!-- Grid de métricas (2 columnas) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <!-- Ventas Brutas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_ventas_background"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💵 Ventas Brutas"
                android:textSize="9sp"
                android:textColor="#64748B"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_ventas_brutas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />
        </LinearLayout>

        <!-- Notas de Crédito -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_danger_background"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 N. Crédito"
                android:textSize="9sp"
                android:textColor="#64748B"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_notas_credito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />
        </LinearLayout>
    </LinearLayout>

    <!-- Segunda fila -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <!-- Ventas Netas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_success_background"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Ventas Netas"
                android:textSize="9sp"
                android:textColor="#64748B"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_ventas_netas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />
        </LinearLayout>

        <!-- Compras -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_compras_background"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛒 Compras"
                android:textSize="9sp"
                android:textColor="#64748B"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_compras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tercera fila -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <!-- Prosegur -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_info_background"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏦 Prosegur"
                android:textSize="9sp"
                android:textColor="#64748B"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_prosegur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />
        </LinearLayout>

        <!-- Izipay -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/card_primary_background"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 Izipay"
                android:textSize="9sp"
                android:textColor="#64748B"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/widget_izipay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E293B" />
        </LinearLayout>
    </LinearLayout>

    <!-- Top Proveedor -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_warning_background"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Top Proveedor"
            android:textSize="9sp"
            android:textColor="#64748B"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/widget_top_proveedor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin datos"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />
    </LinearLayout>

</LinearLayout>
