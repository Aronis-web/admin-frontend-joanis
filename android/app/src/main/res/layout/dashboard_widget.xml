<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dashboard ERP"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ayer"
            android:textSize="12sp"
            android:textColor="#64748B"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Actualizar" />
    </LinearLayout>

    <!-- Filter Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_today"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Hoy"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:background="@drawable/filter_button"
            android:textColor="#64748B"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_yesterday"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Ayer"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:background="@drawable/filter_button_active"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_week"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Semana"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:background="@drawable/filter_button"
            android:textColor="#64748B"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_month"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Mes"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:background="@drawable/filter_button"
            android:textColor="#64748B" />
    </LinearLayout>

    <!-- Data Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas Brutas"
                android:textSize="10sp"
                android:textColor="#64748B" />

            <TextView
                android:id="@+id/widget_ventas_brutas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#10B981" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notas Crédito"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/widget_notas_credito"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#EF4444" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas Netas"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/widget_ventas_netas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#3B82F6" />

        </LinearLayout>

        <!-- Right Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compras"
                android:textSize="10sp"
                android:textColor="#64748B" />

            <TextView
                android:id="@+id/widget_compras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F59E0B" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prosegur"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/widget_prosegur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#8B5CF6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Izipay"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/widget_izipay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#EC4899" />

        </LinearLayout>
    </LinearLayout>

    <!-- Top Proveedor -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:background="#F1F5F9">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Top Proveedor"
            android:textSize="10sp"
            android:textColor="#64748B" />

        <TextView
            android:id="@+id/widget_top_proveedor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin datos"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />
    </LinearLayout>

</LinearLayout>
