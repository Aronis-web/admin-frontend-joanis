# API Configuration
EXPO_PUBLIC_API_URL=https://api.tudominio.com
EXPO_PUBLIC_PUBLIC_ASSETS_PREFIX=/public

# App Configuration
EXPO_PUBLIC_APP_ID=your-app-id-here
EXPO_PUBLIC_ENV=dev

# Google Maps API Key
# IMPORTANT: Get your own key from https://console.cloud.google.com/
# Enable restrictions (HTTP referrers for web, Android/iOS app restrictions for mobile)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Error Tracking (Optional)
SENTRY_DSN=
